{
  "name": "ai-localization-improver",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "next lint",
    "check": "npm run lint && npm run build",
    "pages:build": "next build && bunx @cloudflare/next-on-pages",
    "preview": "bun run pages:build && wrangler pages dev .vercel/output/static",
    "deploy": "bun run pages:build && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "next": "15.1.7",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.1.7",
    "typescript": "^5.8.2",
    "wrangler": "^4.72.0"
  }
}
